    "content.accessibility.record_voice_hint" : {
      "comment" : "Accessibility hint explaining double-tap toggles voice recording",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "اضغط ضغطة مزدوجة لبدء التسجيل، واضغط مرة أخرى للإرسال"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "রেকর্ডিং শুরু করতে দুইবার ট্যাপ করুন, পাঠাতে আবার দুইবার ট্যাপ করুন"
          }
        },
        "de" : {
          "stringUnit" : {
