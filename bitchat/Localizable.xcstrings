    "app_info.sensitive.intro" : {
      "comment" : "Intro paragraph for the sensitive-areas safety guide, setting an honest, non-alarmist tone",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat يقلّل الخطر؛ لكنه لا يجعلك خفيًّا. إذا كنت في مكان معادٍ، فاقرأ هذا قبل أن تنشر — افترض أن القنوات العامة مراقَبة، وتصرّف على هذا الأساس."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat ঝুঁকি কমায়; এটি আপনাকে অদৃশ্য করে না। আপনি যদি কোনো বৈরী জায়গায় থাকেন, পোস্ট করার আগে এটি পড়ুন — ধরে নিন পাবলিক চ্যানেলগুলো নজরদারিতে আছে, এবং সেই অনুযায়ী আচরণ করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat verringert das risiko; es macht dich nicht unsichtbar. wenn du an einem feindlichen ort bist, lies das, bevor du etwas postest — geh davon aus, dass öffentliche kanäle beobachtet werden, und handle danach."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat reduces risk; it does not make you invisible. if you're somewhere hostile, read this before you post — assume public channels are watched, and act like it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat reduce el riesgo; no te vuelve invisible. si estás en un lugar hostil, lee esto antes de publicar: da por hecho que los canales públicos están vigilados, y actúa en consecuencia."
          }
        },
        "fa" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat خطر را کاهش می‌دهد؛ اما شما را نامرئی نمی‌کند. اگر در جایی خطرناک هستید، پیش از ارسال پیام این را بخوانید — فرض کنید کانال‌های عمومی تحت نظر هستند و بر همین اساس رفتار کنید."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "binabawasan ng bitchat ang panganib; hindi ka nito ginagawang di-nakikita. kung nasa mapanganib kang lugar, basahin ito bago ka mag-post — ipagpalagay na binabantayan ang mga public channel, at kumilos nang naaayon."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat réduit le risque ; il ne vous rend pas invisible. si vous êtes en territoire hostile, lisez ceci avant de publier — partez du principe que les canaux publics sont surveillés, et agissez en conséquence."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat מפחית סיכון; הוא לא הופך אותך לבלתי נראה. אם אתה נמצא במקום עוין, קרא זאת לפני שאתה מפרסם — הנח שערוצים ציבוריים נמצאים במעקב, ופעל בהתאם."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat जोखिम कम करता है; यह आपको अदृश्य नहीं बनाता। अगर आप किसी शत्रुतापूर्ण जगह पर हैं, तो पोस्ट करने से पहले इसे पढ़ें — मान लें कि सार्वजनिक चैनलों पर निगरानी है, और उसी के अनुसार व्यवहार करें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat mengurangi risiko; ini tidak membuatmu tak terlihat. jika kamu berada di lingkungan yang berbahaya, baca ini sebelum kamu memposting — anggap kanal publik diawasi, dan bertindaklah sesuai itu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat riduce il rischio; non ti rende invisibile. se ti trovi in un luogo ostile, leggi questo prima di pubblicare — dai per scontato che i canali pubblici siano sorvegliati, e comportati di conseguenza."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat はリスクを減らしますが、あなたを不可視にするわけではありません。敵対的な場所にいるなら、投稿する前にこれを読んでください。公開チャンネルは監視されていると想定し、そのように行動してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat은 위험을 줄여줄 뿐, 당신을 보이지 않게 만들어 주지는 않는다. 적대적인 곳에 있다면 글을 올리기 전에 이 내용을 읽어라 — 공개 채널은 감시받고 있다고 가정하고, 그에 맞게 행동하라."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat mengurangkan risiko; ia tidak menjadikan anda halimunan. jika anda berada di tempat yang bermusuhan, baca ini sebelum anda menghantar mesej — anggap saluran awam diperhatikan, dan bertindaklah seolah-olah begitu."
          }
        },
        "ne" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat ले जोखिम घटाउँछ; यसले तपाईंलाई अदृश्य बनाउँदैन। यदि तपाईं कुनै शत्रुतापूर्ण ठाउँमा हुनुहुन्छ भने, पोस्ट गर्नुअघि यो पढ्नुहोस् — सार्वजनिक च्यानलहरू निगरानीमा छन् भनी मान्नुहोस्, र त्यसै अनुसार व्यवहार गर्नुहोस्।"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat verkleint het risico; het maakt je niet onzichtbaar. als je op een vijandige plek bent, lees dit dan voordat je iets plaatst — ga ervan uit dat openbare kanalen in de gaten worden gehouden, en gedraag je daarnaar."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat zmniejsza ryzyko; nie czyni cię niewidzialnym. jeśli jesteś we wrogim otoczeniu, przeczytaj to, zanim coś opublikujesz — zakładaj, że kanały publiczne są obserwowane, i tak postępuj."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "o bitchat reduz o risco; não te torna invisível. se estás num local hostil, lê isto antes de publicar — parte do princípio de que os canais públicos são vigiados e age como tal."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "o bitchat reduz o risco; ele não te torna invisível. se você está em um lugar hostil, leia isto antes de publicar — presuma que os canais públicos estão sendo vigiados, e aja como tal."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat снижает риск, но не делает вас невидимым. если вы в опасном месте, прочитайте это перед публикацией — считайте, что публичные каналы под наблюдением, и ведите себя соответственно."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat minskar risken; det gör dig inte osynlig. om du befinner dig på en fientlig plats, läs detta innan du postar — utgå från att offentliga kanaler övervakas, och agera därefter."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat ஆபத்தைக் குறைக்கிறது; ஆனால் அது உங்களை கண்ணுக்குத் தெரியாதவராக்காது. நீங்கள் விரோதமான இடத்தில் இருந்தால், பதிவிடும் முன் இதைப் படியுங்கள் — பொது சேனல்கள் கண்காணிக்கப்படுகின்றன என்று கருதி, அதற்கேற்ப நடந்து கொள்ளுங்கள்."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat ช่วยลดความเสี่ยง แต่ไม่ได้ทำให้คุณล่องหน หากคุณอยู่ในพื้นที่ที่เป็นอันตราย อ่านสิ่งนี้ก่อนโพสต์ — ให้ถือว่าช่องสาธารณะถูกจับตามองอยู่ และปฏิบัติตัวเช่นนั้น"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat riski azaltır; sizi görünmez yapmaz. düşman bir bölgedeyseniz, paylaşım yapmadan önce bunu okuyun — herkese açık kanalların izlendiğini varsayın ve buna göre hareket edin."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat знижує ризик; він не робить тебе невидимим. якщо ти у ворожому середовищі, прочитай це, перш ніж писати — вважай, що публічні канали під наглядом, і поводься відповідно."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat خطرہ کم کرتا ہے؛ یہ آپ کو پوشیدہ نہیں بناتا۔ اگر آپ کسی معاندانہ جگہ پر ہیں تو کچھ پوسٹ کرنے سے پہلے یہ پڑھیں — یہ فرض کریں کہ عوامی چینلز کی نگرانی ہو رہی ہے، اور اسی کے مطابق عمل کریں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat giảm rủi ro; nó không khiến bạn trở nên vô hình. nếu bạn đang ở nơi thù địch, hãy đọc phần này trước khi đăng — hãy cho rằng các kênh công khai đang bị theo dõi, và hành động đúng như vậy."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat 能降低风险，但不能让你隐身。如果你身处敌对或危险的环境，在发布任何内容前请先读这一段——请假定公共频道正被监视，并据此行事。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "bitchat 能降低風險，但無法讓你隱形。若你身處敵對環境，發文前請先閱讀本文——假設公開頻道正被監看，並照此行事。"
          }
        }
      }
    },
