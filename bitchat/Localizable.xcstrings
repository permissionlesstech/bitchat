            "value" : "பொது என்றால் கண்காணிக்கப்படுகிறது"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "สาธารณะหมายถึงถูกจับตามอง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "herkese açık, izleniyor demektir"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "публічне означає під наглядом"
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "عوامی یعنی زیرِ نگرانی"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "công khai nghĩa là bị theo dõi"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "公开即被监视"
