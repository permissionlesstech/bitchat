        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "nasconde il tuo ip per i canali posizione. consigliato: attivo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ロケーションチャンネル用にipを隠します。推奨: オン"
