    "app_info.sensitive.help.body" : {
      "comment" : "Guide entry body pointing to external digital-security resources (EFF Surveillance Self-Defense, Access Now Digital Security Helpline)",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذا الدليل يقلّل الخطر؛ لكنه لا يجعلك خفيًّا، ولا يوجد تطبيق يحل محل خطة أمن تشغيلي. لنمذجة التهديدات والاستجابة للحوادث، راجِع «الدفاع عن النفس ضد المراقبة» من EFF (EFF Surveillance Self-Defense) وخط المساعدة للأمن الرقمي من Access Now (Access Now Digital Security Helpline)."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
