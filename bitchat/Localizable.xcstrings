    "app_info.sensitive.identity.body" : {
      "comment" : "Guide entry body explaining what identifying information Bluetooth broadcasts reveal",
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
