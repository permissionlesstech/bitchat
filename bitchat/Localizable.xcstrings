        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "double-tap to start recording, double-tap again to send"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "toca dos veces para empezar a grabar, toca dos veces de nuevo para enviar"
