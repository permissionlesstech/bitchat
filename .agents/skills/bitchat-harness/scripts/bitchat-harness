#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="${BITCHAT_REPO:-$(cd "$SCRIPT_DIR/../../../.." && pwd)}"
CLI="${BITCHAT_CLI:-}"

if [[ ! -d "$REPO" ]]; then
  REPO="$(cd "$SCRIPT_DIR/../../../.." && pwd)"
fi

cd "$REPO"

if [[ -n "$CLI" && -x "$CLI" ]]; then
  exec "$CLI" "$@"
fi

if command -v cli-anything-bitchat >/dev/null 2>&1; then
  exec cli-anything-bitchat "$@"
fi

exec python3 -m cli_anything.bitchat "$@"
