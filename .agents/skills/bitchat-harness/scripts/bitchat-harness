#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_REPO="/Users/jasonxu/Documents/personal/bitchat"
REPO="${BITCHAT_REPO:-$DEFAULT_REPO}"
CLI="${BITCHAT_CLI:-/Users/jasonxu/Library/Python/3.13/bin/cli-anything-bitchat}"

if [[ ! -d "$REPO" ]]; then
  REPO="$(cd "$SCRIPT_DIR/../../.." && pwd)"
fi

cd "$REPO"

if [[ -x "$CLI" ]]; then
  exec "$CLI" "$@"
fi

exec python3 -m cli_anything.bitchat "$@"
