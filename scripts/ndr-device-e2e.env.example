# Copy to .local/ndr-device-e2e.env and fill local values there.
# The .local directory is gitignored.

# Physical iOS device UDID for xcodebuild/devicectl. Leave empty to skip iOS.
IOS_DEVICE_ID=

# Bundle identifier installed on the iOS device. If Local.xcconfig changes the
# default bundle ID, set the resolved ID here.
IOS_BUNDLE_ID=chat.bitchat

# Android checkout and adb serial. Leave ANDROID_SERIAL empty to skip Android.
ANDROID_REPO=../bitchat-android
ANDROID_SERIAL=
ANDROID_PACKAGE=com.bitchat.droid
ANDROID_ACTIVITY=com.bitchat.android.MainActivity

# Uncomment any of these to override auto-detection.
# RUN_MAC=1
# RUN_IOS=1
# RUN_ANDROID=1

# How long to keep collecting logs while the manual device smoke is running.
DURATION_SECONDS=240
